---
import { getAsset } from '~/utils/permalinks';
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link rel="sitemap" href={getAsset('/sitemap-index.xml')} />

<!-- SEO-meta-tags -->
<meta name="description" content="Leer Aikido in Arnhem bij Aikidoschool Sankaku. Aikido-lessen voor beginners en gevorderden. Meld je aan voor een proefles!">
<meta name="author" content="Aikido Arnhem">

<!-- Open Graph (voor delen op sociale media) -->
<meta property="og:title" content="Aikido in Arnhem - Aikido Lessen">
<meta property="og:description" content="Leer Aikido in Arnhem bij Aikidoschool Sankaku. Aikido-lessen voor beginners en gevorderden.">
<meta property="og:image" content={Astro.site + "aikido-lessen-arnhem.jpg"}>
<meta property="og:url" content={Astro.site}>

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Aikido in Arnhem - Aikido Lessen">
<meta name="twitter:description" content="Leer Aikido in Arnhem bij Aikidoschool Sankaku. Aikido-lessen voor beginners en gevorderden.">
<meta name="twitter:image" content={Astro.site + "aikido-lessen-arnhem.jpg"}>
