---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';

import {
  headerData,
  footerData,
  headerDataEn,
  footerDataEn,
} from '~/navigation';
import SideLogo from '~/assets/images/side-logo.svg';
import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
}

const { metadata } = Astro.props;

const isEn = Astro.currentLocale === 'en';
const header = isEn ? headerDataEn : headerData;
const footer = isEn ? footerDataEn : footerData;
---

<Layout metadata={metadata}>
  <slot name="header">
    <Header
      {...header}
      isSticky
      doNotshowRssFeed
      showToggleTheme
      showLanguageSwitcher
      position="left"
    />
  </slot>
  <main>
    <div class="flex flex-row min-h-screen">
      <div class="mx-8 hidden md:block">
        <div class="sticky top-20">
          <SideLogo class="hidden dark:block" fill="white" />
          <SideLogo class="block dark:hidden" fill="navy" />
        </div>
      </div>
      <div class="grow min-h-0">
        <slot />
      </div>
    </div>
  </main>
  <slot name="footer">
    <Footer {...footer} />
  </slot>
</Layout>
