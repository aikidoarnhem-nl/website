---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import TimesWageningen from '~/components/widgets/TimesWageningen.astro';
import FeaturesList from '~/components/FeaturesList.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Locatie Wageningen',
};
---

<Layout metadata={metadata}>
    <Hero2
    title="Locatie Wageningen">

    <Fragment slot="subtitle">
    In Wageningen vind je onze dojo in trainingscentrum Kenkon aan het Nieuwe Kanaal 11:
    </Fragment>

    <Fragment slot="content">
      <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2457.8075955189074!2d5.642422812967424!3d51.973932471805945!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c7addf00457757%3A0x921e41c6a47ffb07!2sAikidoschool%20Wageningen!5e0!3m2!1snl!2snl!4v1752941242956!5m2!1snl!2snl" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </Fragment>

  </Hero2>

  <TimesWageningen/>

  <FeaturesList location="Arnhem"/>

      <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Proefles? Ja!',
        href: '/#proefles',
        icon: 'tabler:download',
      },
    ]}
  >
    <Fragment slot="title">
      Aikido&nbsp;<br class="block sm:hidden" /><span
        class="sm:whitespace-nowrap">bij Sankaku</span
      >
    </Fragment>

    <Fragment slot="subtitle">
      De beste tijd om met aikido te beginnen is nu.<br
        class="hidden md:inline"
      />Wacht niet langer!
    </Fragment>
  </CallToAction>

</Layout>
