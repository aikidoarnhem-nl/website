---
import Layout from '~/layouts/PageLayout.astro';
import GoogleMap from '~/components/widgets/GoogleMap.astro';
const metadata = {
  title: 'Locaties',
};
---

<Layout metadata={metadata}>
  <Fragment>
    <GoogleMap
      header="Locatie Arnhem"
      title="'t Luifeltje"
      href="https://www.google.com/maps/@51.9817756,5.972745,19z?hl=nl-NL"
      address="Dunoweg 2"
      city="6825 ED Arnhem"
      mapid="arnhem"
      centerLat="51.9817756"
      centerLng="5.97274"
      locationLat="51.9817756"
      locationLng="5.972745"
    />
    <GoogleMap
      header="Locatie Wageningen"
      title="KenKon"
      href="https://www.google.com/maps/@51.9817756,5.972745,19z?hl=nl-NL"
      address="Nieuwe kanaal 11"
      city="6709 PA Wageningen"
      mapid="wageningen"
      centerLat="51.97455309999999"
      centerLng="5.642246500000056"
      locationLat="51.9738447"
      locationLng="5.6441740999999865"
    />
  </Fragment>
</Layout>
