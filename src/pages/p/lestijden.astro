---
import Layout from '~/layouts/PageLayout.astro';
import TimesArnhem from '~/components/widgets/TimesArnhem.astro';
import TimesWageningen from '~/components/widgets/TimesWageningen.astro';
import Features from '~/components/widgets/Features.astro';
import FeaturesList from '~/components/FeaturesList.astro';
const metadata = {
  title: 'Lestijden',
};
---
<Layout metadata={metadata}>

  <TimesArnhem/>

  <TimesWageningen/>

  <Features
    title="Vakanties"
    items={[
      {
        title: 'Arnhem kinderen/jeugd',
        description:
          'Er zijn geen jeugd en kinderlessen tijdens de basisschool-vakantie in regio zuid Nederland.',
        icon: 'tabler:calendar',
      },
      {
        title: 'Wageningen kinderen/jeugd',
        description:
          'Er zijn geen jeugd en kinderlessen tijdens de basisschool-vakantie in regio midden Nederland.',
        icon: 'tabler:calendar',
      },
      {
        title: 'Arnhem zomer',
        description:
          'Er zijn geen binnenlessen tijdens de basisschool zomervakantie in regio zuid Nederland.',
        icon: 'tabler:calendar',
      },
      {
        title: 'Wageningen zomer',
        description:
          'Er zijn geen binnenlessen tijdens de basisschool zomervakantie in regio midden Nederland. In die periode zijn er wel elke dinsdag wapenlessen buiten in het Belmonte Arboretum van 18:00 - 19:30.',
        icon: 'tabler:calendar',
      },
      {
        title: 'Feestdagen',
        description:
          'Op officiële feestdagen geven we geen les. Er is geen les op goede vrijdag, 2e paasdag, koninginnedag, hemelvaartsdag de vrijdag na hemelvaart en 2e pinksterdag. In de kerst vakantie is er ook geen les.',
        icon: 'tabler:calendar',
      },
      {
        title: '5 mei',
        description:
          'In Wageningen geven we geen les op 5 mei.',
        icon: 'tabler:calendar',
      },
    ]}
  />

</Layout>