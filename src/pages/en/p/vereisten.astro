---
import Layout from '~/layouts/PageLayout.astro';
import Content from '~/components/widgets/Content.astro';
const metadata = {
  title: 'Requirements',
};
---

<Layout metadata={metadata}>
  <Content
    image={{
      src: '~/assets/images/sumio200.jpg',
      alt: 'Black/white aikido technique',
    }}
    items={[
      {
        icon: 'tabler:download',
        callToAction: {
          text: 'Sixth kyu',
          href: '/kyu/kyu6.php.html',
          target: '_blank',
        },
      },
      {
        icon: 'tabler:download',
        callToAction: {
          text: 'Fifth kyu',
          href: '/kyu/kyu5.php.html',
          target: '_blank',
        },
      },
      {
        icon: 'tabler:download',
        callToAction: {
          text: 'Fourth kyu',
          href: '/kyu/kyu4.php.html',
          target: '_blank',
        },
      },
      {
        icon: 'tabler:download',
        callToAction: {
          text: 'Third kyu',
          href: '/kyu/kyu3.php.html',
          target: '_blank',
        },
      },
      {
        icon: 'tabler:download',
        callToAction: {
          text: 'Second kyu',
          href: '/kyu/kyu2.php.html',
          target: '_blank',
        },
      },
      {
        icon: 'tabler:download',
        callToAction: {
          text: 'First kyu',
          href: '/kyu/kyu1.php.html',
          target: '_blank',
        },
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Kyu grade requirements
      </h3>
      Links (opens a new window!) to the kyu grade requirements.
    </Fragment>
  </Content>

  <Content
    isReversed
    image={{
      src: '~/assets/images/ikkyo200.jpg',
      alt: 'Black/white aikido technique',
    }}
    items={[
      {
        icon: 'tabler:download',
        callToAction: {
          text: 'Kyu-Examenrichtlijnen-aikido.pdf',
          href: '/pdfs/Kyu-Examenrichtlijnen-aikido.pdf',
          target: '_blank',
        },
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Kyu requirements from Tamura sensei
      </h3>
      In Kyu-Examenrichtlijnen-aikido.pdf you will find the kyu examination guidelines
      drawn up by the National Grades Commission Aikido (16 August 1997). The technical
      requirements are in accordance with the national method. For this, the book by
      Nobuyoshi Tamura, L'aikido, méthode nationale (Aikido, the national method) can
      serve as a guide.
    </Fragment>
  </Content>

  <Content
    items={[
      {
        icon: 'tabler:download',
        callToAction: {
          text: 'Aikido principles assessment form',
          href: '/pdfs/dan/aikido-principes.pdf',
          target: '_blank',
        },
      },
      {
        icon: 'tabler:download',
        callToAction: {
          text: 'Vaardigheidseisen_danexamen_aikido',
          href: '/pdfs/dan/vaardigheidseisen_danexamen_aikido.pdf',
          target: '_blank',
        },
      },
      {
        icon: 'tabler:download',
        callToAction: {
          text: 'Aikido dan grade curriculum',
          href: '/pdfs/dan/aikido_dan-graad_curriculum.pdf',
          target: '_blank',
        },
      },
      {
        icon: 'tabler:download',
        callToAction: {
          text: 'Aikido techniques 1st dan - shodan (1/2)',
          href: '/pdfs/dan/aikido_technieken_1dan_shodan_1.pdf',
          target: '_blank',
        },
      },
      {
        icon: 'tabler:download',
        callToAction: {
          text: 'Aikido techniques 1st dan - shodan (2/2)',
          href: '/pdfs/dan/aikido_technieken_1dan_shodan_2.pdf',
          target: '_blank',
        },
      },
      {
        icon: 'tabler:download',
        callToAction: {
          text: 'Aikido techniques 2nd dan - nidan',
          href: '/pdfs/dan/aikido_technieken_2dan_nidan.pdf',
          target: '_blank',
        },
      },
      {
        icon: 'tabler:download',
        callToAction: {
          text: 'Aikido techniques 3rd dan - sandan',
          href: '/pdfs/dan/aikido_technieken_3dan_sandan.pdf',
          target: '_blank',
        },
      },
      {
        icon: 'tabler:download',
        callToAction: {
          text: 'Aikido techniques 4th dan - yondan',
          href: '/pdfs/dan/aikido_technieken_4dan_yondan.pdf',
          target: '_blank',
        },
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Dan grade requirements
      </h3>
      The list of examination requirements as they may be asked (opens a new window!).
    </Fragment>
  </Content>
</Layout>
